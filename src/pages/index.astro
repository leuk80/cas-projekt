---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import AudioPlayer from '../components/AudioPlayer.astro';
import CardGrid from '../components/CardGrid.astro';
---

<Layout title="General Management & Leadership">
  <Header
    title="General Management & Leadership"
    subtitle="The Leadership Toolbox"
  />

  <main class="py-12 space-y-12">
    <AudioPlayer src="/audio/interview.mp3" title="Audio Rahel Engels" />

    <section>
      <CardGrid />
    </section>

    <section class="max-w-3xl mx-auto px-6">
      <div class="rounded-xl overflow-hidden shadow-sm border border-gray-200">
        <iframe
          allow="autoplay *; encrypted-media *; fullscreen *; clipboard-write"
          frameborder="0"
          height="450"
          style="width: 100%; overflow: hidden; border-radius: 12px;"
          sandbox="allow-forms allow-popups allow-same-origin allow-scripts allow-storage-access-by-user-activation allow-top-navigation-by-user-activation"
          src="https://embed.music.apple.com/de/playlist/leadership-jukebox/pl.u-r2yB1aYIPapb1W2"
          loading="lazy"
        ></iframe>
      </div>
    </section>
  </main>

  <footer class="border-t border-gray-200 py-8 text-center text-sm text-gray-400">
    &copy; {new Date().getFullYear()} CAS Projekt
  </footer>
</Layout>
