---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';
import CardGrid from '../components/CardGrid.astro';
---

<Layout title="CAS Projekt">
  <Header
    title="CAS Projekt"
    subtitle="Click each card to explore key concepts"
  />

  <main class="py-12 space-y-12">
    <YouTubeEmbed videoId="dQw4w9WgXcQ" />

    <section>
      <CardGrid />
    </section>
  </main>

  <footer class="border-t border-gray-200 py-8 text-center text-sm text-gray-400">
    &copy; {new Date().getFullYear()} CAS Projekt
  </footer>
</Layout>
