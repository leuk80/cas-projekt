---
interface Props {
  videoId: string;
}

const { videoId } = Astro.props;
---

<div class="max-w-3xl mx-auto px-6">
  <div class="aspect-video rounded-xl overflow-hidden shadow-sm border border-gray-200">
    <iframe
      class="w-full h-full"
      src={`https://www.youtube.com/embed/${videoId}`}
      title="YouTube video"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen
      loading="lazy"
    ></iframe>
  </div>
</div>
