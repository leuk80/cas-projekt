---
interface Props {
  title?: string;
  subtitle?: string;
}

const { title = 'CAS Projekt', subtitle } = Astro.props;
---

<header class="bg-white border-b border-gray-200">
  <div class="max-w-5xl mx-auto px-6 py-8 text-center">
    <h1 class="text-3xl font-semibold tracking-tight text-gray-900">{title}</h1>
    {subtitle && (
      <p class="mt-2 text-gray-500 text-base">{subtitle}</p>
    )}
  </div>
</header>
