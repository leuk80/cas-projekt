---
interface Props {
  keyword: string;
  subtitle?: string;
  text: string;
}

const { keyword, subtitle, text } = Astro.props;
---

<div
  class="flip-card cursor-pointer h-64"
  style="perspective: 1000px"
>
  <div
    class="flip-inner relative w-full h-full transition-transform duration-500"
    style="transform-style: preserve-3d"
  >
    <!-- Front -->
    <div
      class="flip-front absolute inset-0 flex items-center justify-center bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-md transition-shadow"
      style="backface-visibility: hidden"
    >
      <div class="text-center px-4">
        <span class="text-gray-900 font-semibold text-lg block">{keyword}</span>
        {subtitle && <span class="text-gray-500 text-sm mt-1 block">{subtitle}</span>}
      </div>
    </div>

    <!-- Back -->
    <div
      class="flip-back absolute inset-0 flex items-center justify-center bg-gray-50 border border-gray-200 rounded-xl p-5"
      style="backface-visibility: hidden; transform: rotateY(180deg)"
    >
      <p class="text-gray-600 text-xs text-center leading-relaxed">{text}</p>
    </div>
  </div>
</div>

<!-- Zoom overlay (hidden by default) -->
<div class="flip-overlay fixed inset-0 z-50 flex items-center justify-center p-4 pointer-events-none opacity-0 transition-opacity duration-300 ease-out bg-black/50 backdrop-blur-sm">
  <div class="flip-overlay-content bg-white rounded-2xl shadow-2xl w-full max-w-lg max-h-[90vh] overflow-y-auto p-8 relative scale-90 translate-y-6 transition-all duration-300 ease-out">
    <button class="flip-overlay-close absolute top-3 right-4 text-gray-400 hover:text-gray-700 text-2xl leading-none">&times;</button>
    <div class="text-center mb-4">
      <h2 class="text-gray-900 font-bold text-xl">{keyword}</h2>
      {subtitle && <p class="text-gray-500 text-sm mt-1">{subtitle}</p>}
    </div>
    <p class="text-gray-700 text-base leading-relaxed text-center">{text}</p>
  </div>
</div>

<style>
  .flip-inner.flipped {
    transform: rotateY(180deg);
  }

  .flip-overlay.active {
    opacity: 1;
    pointer-events: auto;
  }

  .flip-overlay.active .flip-overlay-content {
    transform: scale(1) translateY(0);
  }

  .flip-overlay.closing .flip-overlay-content {
    transform: scale(0.90) translateY(6px);
    opacity: 0;
  }
</style>

<script>
  document.addEventListener('astro:page-load', initFlipCards);
  document.addEventListener('DOMContentLoaded', initFlipCards);

  function initFlipCards() {
    document.querySelectorAll('.flip-card').forEach(card => {
      if (card.dataset.initialized) return;
      card.dataset.initialized = 'true';

      const inner = card.querySelector('.flip-inner') as HTMLElement;
      const overlay = card.nextElementSibling as HTMLElement;
      if (!overlay?.classList.contains('flip-overlay')) return;

      const closeBtn = overlay.querySelector('.flip-overlay-close') as HTMLElement;

      card.addEventListener('click', () => {
        const isFlipped = inner.classList.contains('flipped');

        if (!isFlipped) {
          // First click: flip the card
          inner.classList.add('flipped');
          // On small screens, open the zoom overlay after flip animation
          if (window.innerWidth < 768) {
            setTimeout(() => openOverlay(overlay), 400);
          }
        } else {
          // Already flipped: on desktop toggle back, on mobile open overlay
          if (window.innerWidth < 768) {
            openOverlay(overlay);
          } else {
            inner.classList.remove('flipped');
          }
        }
      });

      // Close overlay and flip tile back
      closeBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        closeOverlay(overlay, inner);
      });

      overlay.addEventListener('click', (e) => {
        if (e.target === overlay) {
          closeOverlay(overlay, inner);
        }
      });
    });
  }

  function openOverlay(overlay: HTMLElement) {
    // Trigger reflow then add active class for animation
    requestAnimationFrame(() => {
      overlay.classList.add('active');
    });
    document.body.style.overflow = 'hidden';
  }

  function closeOverlay(overlay: HTMLElement, inner?: HTMLElement) {
    overlay.classList.add('closing');
    overlay.classList.remove('active');

    // After close animation finishes, reset and flip tile back
    setTimeout(() => {
      overlay.classList.remove('closing');
      document.body.style.overflow = '';
      if (inner) {
        inner.classList.remove('flipped');
      }
    }, 300);
  }
</script>
